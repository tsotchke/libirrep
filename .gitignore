# build output
bin/
build/
obj/
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exp
*.pdb

# release artifacts — generated, not tracked
release/*/
release/*.tar.gz
release/*.tar.gz.sha256
release/*.tar.gz.sig
!release/.gitkeep

# Lebedev-Laikov 1999 tables (fetched on demand, not tracked)
data/lebedev/

# benchmark output (baseline, coverage and fuzz reports are tracked;
# dated run directories are not)
benchmarks/results/*/
!benchmarks/results/baseline/
!benchmarks/results/coverage/
!benchmarks/results/fuzz/
!benchmarks/results/e3nn_compare/

# editor state
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# coverage (raw profile artefacts only; baseline report under
# benchmarks/results/coverage/ stays tracked)
*.gcno
*.gcda
*.gcov
*.profraw
*.profdata
/build/coverage/

# doxygen
docs/html/
docs/latex/
docs/xml/

# cmake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake
compile_commands.json
